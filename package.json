{
  "name": "kyle_financial",
  "version": "0.1.0",
  "private": true,
  "pnpm": {
    "overrides": {
      "postcss": "8.5.19"
    }
  },
  "scripts": {
    "predev": "pnpm generated-assets:build",
    "dev": "next dev",
    "prebuild": "pnpm generated-assets:build",
    "build": "next build",
    "start": "next start",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "pretest": "pnpm tax-table-registry:build",
    "test": "vitest run",
    "test:watch": "vitest",
    "generated-assets:build": "pnpm tax-table-registry:build && pnpm service-worker:build",
    "service-worker:build": "node scripts/build-service-worker.mjs",
    "tax-table-registry:build": "node scripts/build-tax-table-registry.mjs",
    "tax:longevity-drill": "node scripts/longevity-drill.mjs",
    "tax:import-states": "tsx scripts/import-state-tax-table.mjs",
    "auth:invite": "node --env-file-if-exists=.env.local --import tsx scripts/create-registration-invite.ts",
    "db:migrate": "tsx scripts/migrate.ts",
    "preverify": "pnpm generated-assets:build",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "fake-indexeddb": "^6.2.5",
    "fast-check": "^4.9.0",
    "prettier": "^3.9.5",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
