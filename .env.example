# Server-only. Production points to the supplied Neon database.
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Server-only, random 32+ byte value used to mint email-bound signup invitations.
REGISTRATION_SECRET=

# Automated tests refuse any database whose name does not end in `_test`.
TEST_DATABASE_URL=postgresql://localhost:5432/kyle_financial_test

# Demo seeding is explicit and never runs during app startup.
DEMO_EMAIL=demo@example.com
DEMO_PASSWORD=replace-with-a-local-demo-password
